<Window x:Class="PersonalProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Height="112" VerticalAlignment="Top" Width="155" Margin="0,76,0,0">
            <Button Content="HOME" FontSize="18"/>
            <Button Content="GUESS" FontSize="18"/>
            <Button Content="POKEDEX" FontSize="18"/>
            <Button Content="HISTORY" Click="Button_Click" FontSize="18"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="60" Margin="0,374,0,0" VerticalAlignment="Top" Width="155">
            <Button Content="SETTINGS" FontSize="18"/>
            <Button Content="CONTACT" FontSize="18"/>
        </StackPanel>
        <Image HorizontalAlignment="Left" Height="430" Margin="1,0,0,0" VerticalAlignment="Top" Width="154"/>
    </Grid>
</Window>
