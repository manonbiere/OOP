<Window x:Class="PersonalProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Width="155">
            <Image Height="648" Source="/Image/fond bleue.png" Stretch="Fill" Width="1152"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="104" VerticalAlignment="Top" Width="154" Margin="0,124,0,0" RenderTransformOrigin="0.565,0.351">
            <Button Content="HOME" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button Content="GUESS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button Content="POKEDEX" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button Content="HISTORY" Click="Button_Click" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="60" Margin="0,348,0,0" VerticalAlignment="Top" Width="155">
            <Button Content="SETTINGS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button Content="CONTACT" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
        </StackPanel>
        <Image Margin="-2,13,637,300" Source="/Image/Poke.png" Stretch="Fill"/>
    </Grid>
</Window>
