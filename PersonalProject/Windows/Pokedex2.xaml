<Window x:Class="PersonalProject.Windows.Pokedex2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject.Windows"
        mc:Ignorable="d"
        Title="Pokedex2" Height="450" Width="800"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Width="155">
            <Image Height="648" Source="/Image/fond bleue.png" Stretch="Fill" Width="1152"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Left" Height="228" VerticalAlignment="Top" Width="154" RenderTransformOrigin="0.565,0.351">
            <Button x:Name="btnHome" Content=" " FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Height="144"/>
            <Button x:Name="btnGuess" Content="GUESS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnPokedex" Content="POKEDEX" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnHistory" Content="HISTORY" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
        </StackPanel>

        <Image Margin="0,10,635,303" Source="/Image/Poke.png" Stretch="Fill"/>
        <Label Content="Type :" HorizontalAlignment="Left" Height="26" Margin="418,94,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Generation :" HorizontalAlignment="Left" Height="26" Margin="418,125,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Category :" HorizontalAlignment="Left" Height="26" Margin="418,221,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Talent :" HorizontalAlignment="Left" Height="26" Margin="418,252,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Evolution :" HorizontalAlignment="Left" Height="26" Margin="418,283,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Index :" HorizontalAlignment="Left" Height="26" Margin="418,314,0,0" VerticalAlignment="Top" Width="261"/>
        <Image Margin="181,94,400,94" Source="/Image/fond bleue.png" Stretch="Fill"/>
        <Button Content="Next" HorizontalAlignment="Left" Margin="663,371,0,0" VerticalAlignment="Top" Width="78" FontSize="14" Background="#FF99D9EA"/>
        <Button Content="Prev" HorizontalAlignment="Left" Margin="230,371,0,0" VerticalAlignment="Top" Width="78" FontSize="14" Background="#FF99D9EA"/>
        <Label Content="NAME" HorizontalAlignment="Left" Height="44" Margin="308,27,0,0" VerticalAlignment="Top" Width="286" FontSize="24"/>
        <Label Content="Height :" HorizontalAlignment="Left" Height="26" Margin="418,156,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Weight :" HorizontalAlignment="Left" Height="26" Margin="418,187,0,0" VerticalAlignment="Top" Width="261"/>
    </Grid>
</Window>
