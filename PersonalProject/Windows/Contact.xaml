<Window x:Class="PersonalProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Width="155">
            <Image Height="648" Source="/Image/fond bleue.png" Stretch="Fill" Width="1152"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="228" VerticalAlignment="Top" Width="154" RenderTransformOrigin="0.565,0.351">
            <Button x:Name="btnHome" Content=" " FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Height="144" Click="Button_Click_1"/>
            <Button x:Name="btnGuess" Content="GUESS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnPokedex" Content="POKEDEX" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnHistory" Content="HISTORY" Click="Button_Click" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="60" Margin="0,348,0,0" VerticalAlignment="Top" Width="155">
            <Button x:Name="btnSettings" Content="SETTINGS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnContact" Content="CONTACT" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
        </StackPanel>
        <Image Margin="0,10,635,303" Source="/Image/Poke.png" Stretch="Fill"/>
        <Label Content="If any problem where to happen to this project please contact us with the following adress :&#xD;&#xA; S00295652@atu.ie" HorizontalAlignment="Left" Height="59" Margin="230,158,0,0" VerticalAlignment="Top" Width="504"/>
    </Grid>
</Window>
