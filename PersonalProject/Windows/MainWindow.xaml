<Window x:Class="PersonalProject.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject.Windows"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="800"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Height="500" VerticalAlignment="Center" Width="155">
            <Image Height="648" Source="/Image/fond bleue.png" Stretch="Fill" Width="1152"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="228" VerticalAlignment="Top" Width="154" RenderTransformOrigin="0.565,0.351">
            <Button x:Name="btnHome" Content=" " FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Height="144"/>
            <Button x:Name="btnGuess" Content="GUESS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Click="btnGuess_Click"/>
            <Button x:Name="btnPokedex" Content="POKEDEX" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Click="btnPokedex_Click"/>
            <Button x:Name="btnHistory" Content="HISTORY" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Click="btnHistory_CLick"/>
        </StackPanel>

        <Image Margin="0,10,0,0" Source="/Image/Poke.png" Stretch="Fill" Height="121" VerticalAlignment="Top" HorizontalAlignment="Left" Width="165"/>
        <Label Content="Quick news" HorizontalAlignment="Left" Height="41" Margin="182,30,0,0" VerticalAlignment="Top" Width="592"/>
        <Label Content="How to use the app ?" HorizontalAlignment="Left" Height="322" Margin="182,86,0,0" VerticalAlignment="Top" Width="280"/>
        <Label Content="How to use the guessing game ?" HorizontalAlignment="Left" Height="322" Margin="494,86,0,0" VerticalAlignment="Top" Width="280"/>
    </Grid>
</Window>
