<Window x:Class="PersonalProject.Windows.History"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject.Windows"
        mc:Ignorable="d"
        Title="History" Height="500" Width="800"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Grid>
        <Image Source="/Image/Background/Background1.jpg" Stretch="Fill"/>
        <Image Margin="378,45,0,0" Source="/Image/carre blanc 100x100.png" Stretch="Fill" Opacity="0.8" Height="68" VerticalAlignment="Top" HorizontalAlignment="Left" Width="390"/>
        <Image Margin="378,118,0,0" Source="/Image/carre blanc 100x100.png" Stretch="Fill" Opacity="0.8" Height="315" VerticalAlignment="Top" HorizontalAlignment="Left" Width="390"/>
        <Image Margin="175,339,0,0" Source="/Image/carre blanc 100x100.png" Stretch="Fill" Opacity="0.8" Height="18" VerticalAlignment="Top" HorizontalAlignment="Left" Width="37"/>

        <StackPanel HorizontalAlignment="Left" Height="500" VerticalAlignment="Center" Width="155">
            <Image Height="500" Source="/Image/carre blanc 100x100.png" Stretch="Fill" Width="158" Opacity="0.75"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="228" VerticalAlignment="Top" Width="154" RenderTransformOrigin="0.565,0.351">
            <Button x:Name="btnHome" Content=" " FontSize="18" BorderThickness="0,0,0,0" Height="144" Click="btnHome_Click">
                <Button.Background>
                    <SolidColorBrush Color="White" Opacity="0.10"/>
                </Button.Background>
            </Button>
            <Button x:Name="btnGuess" Content="GUESS" FontSize="18" BorderThickness="0,0,0,0" Click="btnGuess_Click">
                <Button.Background>
                    <SolidColorBrush Color="White" Opacity="0.72"/>
                </Button.Background>
            </Button>
            <Button x:Name="btnPokedex" Content="POKEDEX" FontSize="18" BorderThickness="0,0,0,0" Click="btnPokedex_Click">
                <Button.Background>
                    <SolidColorBrush Color="White" Opacity="0.75"/>
                </Button.Background>
            </Button>
            <Button x:Name="btnHistory" Content="HISTORY" FontSize="18" BorderThickness="0,0,0,0" Click="btnHistory_Click">
                <Button.Background>
                    <SolidColorBrush Color="White" Opacity="0.75"/>
                </Button.Background>
            </Button>
        </StackPanel>

        <Image Margin="0,10,0,0" Source="/Image/Poke.png" Stretch="Fill" Height="121" VerticalAlignment="Top" HorizontalAlignment="Left" Width="165"/>
        <Image x:Name="imgPoke" Margin="175,45,0,0" Source="/Image/carre blanc 100x100.png" Stretch="Fill" Height="245" VerticalAlignment="Top" HorizontalAlignment="Left" Width="189" Opacity="0.8"/>

        <ComboBox x:Name="lbxPoke" HorizontalAlignment="Left" Margin="176,368,0,0" VerticalAlignment="Top" Width="188" SelectionChanged="lbxPoke_SlectionChanged" Opacity="0.8">
            <ComboBox.Background>
                <LinearGradientBrush EndPoint="0,1" Opacity="0.79">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FFE5E5E5" Offset="1"/>
                </LinearGradientBrush>
            </ComboBox.Background>
        </ComboBox>
        <TextBlock x:Name="txbQuickInfo" HorizontalAlignment="Left" Margin="378,45,0,0" TextWrapping="Wrap" Text="Generic information :" VerticalAlignment="Top" Height="63" Width="390"/>
        <TextBlock x:Name="txbHistory" HorizontalAlignment="Left" Margin="378,113,0,0" TextWrapping="Wrap" Text="Behaviour :" VerticalAlignment="Top" Height="320" Width="390"/>

        <Label Content="Filtre" HorizontalAlignment="Left" Margin="175,335,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txb_Filtre" HorizontalAlignment="Left" Margin="222,339,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120" Opacity="0.8"/>
        <Button x:Name="btnok" Content="ok" HorizontalAlignment="Left" Margin="347,339,0,0" VerticalAlignment="Top" Click="Click_btnok">
            <Button.Background>
                <SolidColorBrush Color="#FFF7F9FA" Opacity="0.8"/>
            </Button.Background>
        </Button>
    </Grid>
</Window>
