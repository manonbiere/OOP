<Window x:Class="PersonalProject.Windows.History"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject.Windows"
        mc:Ignorable="d"
        Title="History" Height="500" Width="800"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Height="500" VerticalAlignment="Center" Width="155">
            <Image Height="648" Source="/Image/fond bleue.png" Stretch="Fill" Width="1152"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Left" Height="228" VerticalAlignment="Top" Width="154" RenderTransformOrigin="0.565,0.351">
            <Button x:Name="btnHome" Content=" " FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Height="144" Click="btnHome_Clck"/>
            <Button x:Name="btnGuess" Content="GUESS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Click="btnGuess_Click"/>
            <Button x:Name="btnPokedex" Content="POKEDEX" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Click="btnPokedex_Click"/>
            <Button x:Name="btnHistory" Content="HISTORY" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Click="btnHistory_Click"/>
        </StackPanel>

        <Image Margin="0,10,0,0" Source="/Image/Poke.png" Stretch="Fill" Height="121" VerticalAlignment="Top" HorizontalAlignment="Left" Width="165"/>
        <Image x:Name="imgPoke" Margin="175,45,0,0" Source="/Image/fond bleue.png" Stretch="Fill" Height="245" VerticalAlignment="Top" HorizontalAlignment="Left" Width="189"/>

        <ComboBox x:Name="lbxPoke" HorizontalAlignment="Left" Margin="175,366,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="lbxPoke_SlectionChanged"/>
        <TextBlock x:Name="txbQuickInfo" HorizontalAlignment="Left" Margin="378,45,0,0" TextWrapping="Wrap" Text="Generic information :" VerticalAlignment="Top" Height="63" Width="390"/>
        <TextBlock x:Name="txbHistory" HorizontalAlignment="Left" Margin="378,113,0,0" TextWrapping="Wrap" Text="Behaviour :" VerticalAlignment="Top" Height="320" Width="390"/>
    </Grid>
</Window>
