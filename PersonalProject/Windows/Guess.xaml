<Window x:Class="PersonalProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Height="434" VerticalAlignment="Center" Width="155">
            <Image Height="648" Source="/Image/fond bleue.png" Stretch="Fill" Width="1152"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="228" VerticalAlignment="Top" Width="154" RenderTransformOrigin="0.565,0.351">
            <Button x:Name="btnHome" Content=" " FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0" Height="144" Click="Button_Click_1"/>
            <Button x:Name="btnGuess" Content="GUESS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnPokedex" Content="POKEDEX" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnHistory" Content="HISTORY" Click="Button_Click" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Height="60" Margin="0,348,0,0" VerticalAlignment="Top" Width="155">
            <Button x:Name="btnSettings" Content="SETTINGS" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
            <Button x:Name="btnContact" Content="CONTACT" FontSize="18" Background="#FF99D9EA" BorderThickness="0,0,0,0"/>
        </StackPanel>
        <Image Margin="0,10,635,303" Source="/Image/Poke.png" Stretch="Fill"/>
        <Label Content="Type :" HorizontalAlignment="Left" Height="26" Margin="418,45,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Generation :" HorizontalAlignment="Left" Height="26" Margin="418,76,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="HP :" HorizontalAlignment="Left" Height="26" Margin="418,107,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Evolution :" HorizontalAlignment="Left" Height="26" Margin="418,138,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Clue 1 :" HorizontalAlignment="Left" Height="26" Margin="418,169,0,0" VerticalAlignment="Top" Width="261"/>
        <Label Content="Clue 2 :" HorizontalAlignment="Left" Height="26" Margin="418,200,0,0" VerticalAlignment="Top" Width="261"/>
        <Image Margin="181,22,400,184" Source="/Image/fond bleue.png" Stretch="Fill"/>
        <Button Content="   NEXT   " HorizontalAlignment="Left" Margin="666,297,0,0" VerticalAlignment="Top" Background="#FF99D9EA" Width="88"/>
        <Button Content="   SKIP   " HorizontalAlignment="Left" Margin="666,353,0,0" VerticalAlignment="Top" Width="88" Background="#FF99D9EA"/>
        <ComboBox HorizontalAlignment="Left" Margin="344,296,0,0" VerticalAlignment="Top" Width="187"/>
        <Label Content="Your Guess :" HorizontalAlignment="Left" Margin="253,294,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>
